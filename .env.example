# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_DB=followupcrm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeMe!

PGADMIN_EMAIL=admin@followupcrm.local
PGADMIN_PASSWORD=ChangeMe!

# ── Backend (.NET 8) ──────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=followupcrm;Username=postgres;Password=ChangeMe!
Jwt__Key=followup-crm-dev-secret-key-minimum-32-characters!
Jwt__Issuer=FollowUpCrm
Jwt__Audience=FollowUpCrmUsers
Jwt__AccessTokenExpiryMinutes=60
Jwt__RefreshTokenExpiryDays=7

# ── CORS ──────────────────────────────────────────────────────────────
Cors__AllowedOrigins__0=http://localhost:4200

# ── Frontend (Angular) ───────────────────────────────────────────────
# These map to frontend/src/environments/environment.ts
# apiUrl is proxied via nginx in Docker, or direct in dev
API_URL=http://localhost:8080/api

# ── Docker Compose ────────────────────────────────────────────────────
# Port mappings (change if conflicts on host)
POSTGRES_PORT=5432
PGADMIN_PORT=5050
API_PORT=8080
FRONTEND_PORT=80